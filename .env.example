APP_NAME=skeleton
APP_ENV=dev

DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=dedup_content
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_COLLATION=
DB_PREFIX=
# PostgreSQL search_path；第一项是模型默认访问的数据 schema。
DB_SCHEMA=dedup_content,public
DB_POOL_MIN_CONNECTIONS=1
DB_POOL_MAX_CONNECTIONS=4
DB_POOL_CONNECT_TIMEOUT=10
DB_POOL_WAIT_TIMEOUT=3
DB_MAX_IDLE_TIME=60
DB_REBUILD_USERNAME=postgres
DB_REBUILD_PASSWORD=
DB_REBUILD_POOL_MAX_CONNECTIONS=1

REDIS_HOST=localhost
REDIS_AUTH=(null)
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_MIN_CONNECTIONS=1
REDIS_POOL_MAX_CONNECTIONS=4
REDIS_POOL_CONNECT_TIMEOUT=10
REDIS_POOL_WAIT_TIMEOUT=3
REDIS_MAX_IDLE_TIME=60

# PHP 去重算法与运行参数。结构参数改变后必须使用新generation并重建PG/Redis索引。
DEDUPE_ALGORITHM_VERSION=v1
DEDUPE_LEVELS=content_hash,simhash,minhash
DEDUPE_RESULT_LIMIT=20
DEDUPE_SAMPLE_TEXT_LENGTH=160
DEDUPE_LOW_INFORMATION_MIN_LENGTH=30
DEDUPE_LOW_INFORMATION_MIN_ALPHANUMERIC=10
DEDUPE_LOW_INFORMATION_TOKEN_RATIO=0.65
DEDUPE_BRACKET_TOKEN_MAX_LENGTH=20
DEDUPE_BITS=128
DEDUPE_BANDS=8
DEDUPE_NGRAM=5
DEDUPE_MAX_HAMMING=25
DEDUPE_MAX_BUCKET_SIZE=1000
DEDUPE_LSH_MAX_BUCKET_SIZE=2000
DEDUPE_API_MAX_SIMHASH_CHECKS=200
DEDUPE_MINHASH_NGRAM=5
DEDUPE_MINHASH_NUM_PERM=128
DEDUPE_MINHASH_BANDS=32
DEDUPE_MINHASH_ROWS=1
DEDUPE_MINHASH_JACCARD_THRESHOLD=0.4
DEDUPE_MINHASH_MAX_CANDIDATES=50
DEDUPE_MINHASH_MAX_BUCKET_SIZE=1000
DEDUPE_MINHASH_LSH_MAX_BUCKET_SIZE=2000
DEDUPE_API_MAX_MINHASH_CHECKS=200

# 默认关闭；完成 band created_at 迁移后，在构建 generation 前开启。
# 尚无 active generation 时查询会自动回退 PostgreSQL，构建期间在线写入 building generation。
DEDUPE_REDIS_INDEX_ENABLED=0
DEDUPE_REDIS_INDEX_PREFIX=dedupe
DEDUPE_REDIS_INDEX_TIMEZONE=Asia/Shanghai
DEDUPE_REDIS_INDEX_RETENTION_DAYS=10
DEDUPE_REDIS_INDEX_GRACE_DAYS=2
DEDUPE_BAND_CREATED_AT_WRITE_ENABLED=0
DEDUPE_BAND_DATE_FILTER_ENABLED=0
DEDUPE_BLOOM_EXPANSION=2
DEDUPE_BLOOM_WRITE_BATCH_SIZE=1000

DEDUPE_EXACT_BLOOM_ENABLED=1
DEDUPE_EXACT_BLOOM_ERROR_RATE=0.0001
DEDUPE_EXACT_BLOOM_CAPACITY=10000000
DEDUPE_EXACT_BLOOM_EXTERNAL_ID_CAPACITY=10000000

DEDUPE_MINHASH_BLOOM_ENABLED=1
DEDUPE_MINHASH_BLOOM_ERROR_RATE=0.00001
DEDUPE_MINHASH_BLOOM_CONTENT_DAILY_CAPACITY=1300000
DEDUPE_MINHASH_BLOOM_TITLE_DAILY_CAPACITY=1300000
