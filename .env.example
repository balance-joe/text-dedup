APP_NAME=skeleton
APP_ENV=dev

DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=dedup_content
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_COLLATION=
DB_PREFIX=
# PostgreSQL search_path；第一项是模型默认访问的数据 schema。
DB_SCHEMA=dedup_content,public

REDIS_HOST=localhost
REDIS_AUTH=(null)
REDIS_PORT=6379
REDIS_DB=0
