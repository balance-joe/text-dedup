APP_NAME=skeleton
APP_ENV=dev

# Read-only PostgreSQL account used by the dedupe query service.
DEDUPE_PG_HOST=127.0.0.1
DEDUPE_PG_PORT=5432
DEDUPE_PG_DATABASE=dedupe
DEDUPE_PG_USERNAME=dedupe_readonly
DEDUPE_PG_PASSWORD=change-me
DEDUPE_PG_POOL_MIN_CONNECTIONS=1
DEDUPE_PG_POOL_MAX_CONNECTIONS=10
DEDUPE_PG_CONNECT_TIMEOUT=5.0
DEDUPE_PG_WAIT_TIMEOUT=3.0
DEDUPE_PG_MAX_IDLE_TIME=60.0

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hyperf
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

REDIS_HOST=localhost
REDIS_AUTH=(null)
REDIS_PORT=6379
REDIS_DB=0
